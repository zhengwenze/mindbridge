AGENT_FRAMEWORK=langgraph
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_AUTO_PULL=false
DOCKER_OLLAMA_BASE_URL=http://host.docker.internal:11434
DOCKER_OLLAMA_AUTO_PULL=false
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
FINETUNED_MODEL_NAME=mindbridge-qwen2.5-7b-ft:latest
FINETUNED_MODEL_DIR=models/mindbridge-qwen2.5-7b-ft
FINETUNED_MODEL_FILE=mindbridge-qwen2.5-7b-ft-q4_k_m.gguf
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DATABASE_URL=mysql+pymysql://mindbridge:mindbridge@mysql:3306/mindbridge?charset=utf8mb4
REDIS_URL=redis://redis:6379/0
REDIS_MEMORY_TTL_SECONDS=86400
REDIS_MEMORY_MAX_MESSAGES=40
REDIS_SOCKET_TIMEOUT_SECONDS=2
SERVER_HOST=127.0.0.1
SERVER_PORT=8080
KNOWLEDGE_TOP_K=4
KNOWLEDGE_CANDIDATE_K=16
KNOWLEDGE_HYBRID_VECTOR_WEIGHT=0.65
KNOWLEDGE_HYBRID_BM25_WEIGHT=0.35
KNOWLEDGE_RERANK_ENABLED=true
KNOWLEDGE_VECTOR_ENABLED=true
KNOWLEDGE_VECTOR_REQUIRED=false
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=mindbridge_knowledge
CHROMA_SNAPSHOT_DIR=data/chroma-snapshots
CHROMA_SNAPSHOT_KEEP=5
EMBEDDING_TIMEOUT_SECONDS=30
RAG_EVAL_ENABLED=false
RAG_EVAL_EXIT_AFTER_RUN=false
TOOL_QUEUE_ENABLED=true
TOOL_QUEUE_POLL_INTERVAL_SECONDS=1
TOOL_QUEUE_BATCH_SIZE=10
TOOL_QUEUE_MAX_ATTEMPTS=3
TOOL_QUEUE_RETRY_DELAY_SECONDS=15
TOOL_QUEUE_EXCEL_WORKERS=1
TOOL_QUEUE_EMAIL_WORKERS=2
ALERT_EMAIL_RATE_LIMIT_PER_MINUTE=30
ALERT_EMAIL_DELIVERY_MODE=log
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_SUBJECT_PREFIX=[MindBridge 高风险预警]
